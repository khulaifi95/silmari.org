---
import { getCollection } from "astro:content";
import { SITE } from "@/consts";
import Layout from "@/layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<Layout>
  <section class="space-y-2 mb-10">
    <h1 class="text-2xl font-semibold">{SITE.title}</h1>
    <p class="text-zinc-600 dark:text-zinc-400">{SITE.description}</p>
  </section>

  <section>
    <h2 class="text-sm uppercase tracking-wide text-zinc-500 mb-4">Posts</h2>
    <ul class="space-y-4">
      {
        posts.map((post) => (
          <li>
            <a href={`/posts/${post.id}`} class="group block">
              <div class="flex justify-between gap-4">
                <span class="font-medium group-hover:underline">{post.data.title}</span>
                <time class="text-sm text-zinc-500 shrink-0">
                  {dateFmt.format(post.data.pubDatetime)}
                </time>
              </div>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-1">{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
